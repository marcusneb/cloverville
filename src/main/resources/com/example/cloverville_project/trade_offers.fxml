<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<?import javafx.scene.layout.VBox?>
<AnchorPane prefHeight="448.0"
            prefWidth="600.0"
            stylesheets="@main.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cloverville_project.TradeOffersController">

    <children>


        <Button text="← Back"
                layoutX="20"
                layoutY="15"
                styleClass="button-secondary"
                onAction="#handleBackToMain"/>

        <!-- TRADE TABLE -->
        <TableView fx:id="tradeTable"
                   layoutX="23"
                   layoutY="60"
                   prefHeight="200"
                   prefWidth="555"
                   styleClass="card">
            <columns>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="140"/>
                <TableColumn fx:id="ownerColumn" text="Owner" prefWidth="120"/>
                <TableColumn fx:id="offerColumn" text="Trade Offer" prefWidth="140"/>
                <TableColumn fx:id="priceColumn" text="Price / Service" prefWidth="140"/>
            </columns>
        </TableView>


        <Label layoutX="23" layoutY="270" text="Owner"/>
        <Label layoutX="199" layoutY="270" text="Trade Offer"/>
        <Label layoutX="306" layoutY="270" text="Price / Service"/>


        <ComboBox fx:id="ownerComboBox"
                  layoutX="23"
                  layoutY="295"
                  prefWidth="150"/>

        <TextField fx:id="offerField"
                   layoutX="199"
                   layoutY="295"
                   prefWidth="95"/>

        <TextField fx:id="priceField"
                   layoutX="306"
                   layoutY="295"
                   prefWidth="95"/>


        <VBox layoutX="430"
              layoutY="285"
              spacing="4">

            <Button text="Add Offer"
                    styleClass="button-primary"
                    onAction="#handleAddOffer"/>

            <Button text="Edit Selected"
                    styleClass="button-small"
                    onAction="#handleEditOffer"/>

            <Button text="Delete Selected"
                    styleClass="button-small"
                    onAction="#handleDeleteOffer"/>
        </VBox>


        <Text layoutX="23"
              layoutY="365"
              text="Assign the trade offer"/>

        <ComboBox fx:id="residentComboBox"
                  layoutX="23"
                  layoutY="385"
                  prefWidth="150"
                  promptText="Select Resident"/>

        <ComboBox fx:id="taskComboBox"
                  layoutX="185"
                  layoutY="385"
                  prefWidth="150"
                  promptText="Select a trade offer"/>

        <Button text="Assign to Resident"
                layoutX="370"
                layoutY="385"
                styleClass="button-primary"
                onAction="#handleAssignOffer"/>

    </children>
</AnchorPane>
