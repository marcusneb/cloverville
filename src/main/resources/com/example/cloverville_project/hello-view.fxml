<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.cloverville_project.HelloController"
            stylesheets="@main.css"
            prefWidth="600"
            prefHeight="400">

    <children>

        <VBox spacing="25"
              layoutX="30"
              layoutY="30"
              prefWidth="540">


            <VBox styleClass="card" spacing="10">
                <Label fx:id="communityPoolLabel"
                       text="🌱 Community Pool: 0"
                       styleClass="label-title"/>

                <Button text="Reset Personal Points"
                        styleClass="button-secondary"
                        onAction="#handleResetPersonalPoints"/>
            </VBox>


            <VBox spacing="15" alignment="CENTER">

                <!-- ROW 1 -->
                <HBox spacing="20" alignment="CENTER">
                    <Button text="Trade Offers"
                            styleClass="button-primary"
                            onAction="#openTradeOffers"/>

                    <Button text="Residents"
                            styleClass="button-primary"
                            onAction="#openResidents"/>

                    <Button text="Green Actions"
                            styleClass="button-primary"
                            onAction="#openGreenActions"/>
                </HBox>

                <!-- ROW 2 -->
                <HBox spacing="20" alignment="CENTER">
                    <Button text="Assign Communal Task"
                            styleClass="button-primary"
                            onAction="#handleGoToCompleteTask"/>

                    <Button text="Manage Tasks"
                            styleClass="button-primary"
                            onAction="#handleGoToTaskPage"/>
                </HBox>

            </VBox>

        </VBox>

    </children>
</AnchorPane>
